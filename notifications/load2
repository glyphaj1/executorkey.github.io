local function tw(obj, props, t, style, dir)
    local info = TweenInfo.new(
        t     or 0.4,
        style or Enum.EasingStyle.Quint,
        dir   or Enum.EasingDirection.Out
    )
    local tween = TweenService:Create(obj, info, props)
    tween:Play()
    return tween
end

local dragging  = false
local dragStart = nil
local startPos  = nil

titleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        dragging  = true
        dragStart = input.Position
        startPos  = panel.Position
    end
end)

UIS.InputChanged:Connect(function(input)
    if not dragging then return end
    if input.UserInputType == Enum.UserInputType.MouseMovement
    or input.UserInputType == Enum.UserInputType.Touch then
        local delta = input.Position - dragStart
        panel.Position = UDim2.new(
            startPos.X.Scale, startPos.X.Offset + delta.X,
            startPos.Y.Scale, startPos.Y.Offset + delta.Y
        )
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1
    or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

local minimised = false

minBtn.MouseButton1Click:Connect(function()
    minimised = not minimised
    if minimised then
        tw(panel, {Size = UDim2.new(0, PANEL_W, 0, PANEL_H_MINI)}, 0.3, Enum.EasingStyle.Quint)
        minBtn.Text = "+"
    else
        tw(panel, {Size = UDim2.new(0, PANEL_W, 0, PANEL_H_FULL)}, 0.35, Enum.EasingStyle.Back)
        minBtn.Text = "–"
    end
end)

minBtn.MouseEnter:Connect(function()
    tw(minBtn, {BackgroundTransparency = 0, TextColor3 = Color3.fromRGB(230,230,230)}, 0.12)
end)
minBtn.MouseLeave:Connect(function()
    tw(minBtn, {BackgroundTransparency = 0.4, TextColor3 = Color3.fromRGB(150,150,150)}, 0.12)
end)

local bodyLabels = {subLabel, statusLabel, pctLabel, timerLabel}

local function fadeIn()
    tw(panel,       {BackgroundTransparency = 0}, 0.4)
    tw(panelStroke, {Transparency = 0}, 0.4)
    task.wait(0.1)
    tw(titleBar,  {BackgroundTransparency = 0}, 0.3)
    tw(sep,       {BackgroundTransparency = 0}, 0.3)
    tw(titleIcon, {BackgroundTransparency = 0}, 0.3)
    tw(titleText, {TextTransparency = 0}, 0.3)
    task.wait(0.1)
    for _, l in ipairs(bodyLabels) do
        tw(l, {TextTransparency = 0}, 0.35)
    end
    tw(barTrack, {BackgroundTransparency = 0}, 0.35)
    task.wait(0.2)
end

local function fadeOut()
    local FT = 0.4
    for _, l in ipairs(bodyLabels) do
        tw(l, {TextTransparency = 1}, FT, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
    end
    tw(titleText,   {TextTransparency = 1}, FT, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
    tw(barTrack,    {BackgroundTransparency = 1}, FT, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
    tw(sep,         {BackgroundTransparency = 1}, FT, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
    tw(titleIcon,   {BackgroundTransparency = 1}, FT, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
    tw(panelStroke, {Transparency = 1}, FT, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
    task.wait(FT - 0.05)
    local last = tw(panel, {
        BackgroundTransparency = 1,
        Position = UDim2.new(
            panel.Position.X.Scale, panel.Position.X.Offset,
            panel.Position.Y.Scale, panel.Position.Y.Offset - 10
        )
    }, 0.35, Enum.EasingStyle.Quint, Enum.EasingDirection.In)
    last.Completed:Wait()
    screenGui:Destroy()
end

local function runLoadingScreen()
    fadeIn()

    local elapsed     = 0
    local msgCount    = #STATUS_MESSAGES
    local msgInterval = LOAD_TIME / msgCount
    local lastMsg     = 0
    local msgIdx      = 1

    while elapsed < LOAD_TIME do
        local dt = task.wait(0.033)
        elapsed  = math.min(elapsed + dt, LOAD_TIME)
        local p  = elapsed / LOAD_TIME

        barFill.Size    = UDim2.new(p, 0, 1, 0)
        pctLabel.Text   = math.floor(p * 100) .. "%"
        timerLabel.Text = math.floor(elapsed) .. "s  /  " .. LOAD_TIME .. "s"

        if (elapsed - lastMsg) >= msgInterval and msgIdx <= msgCount then
            lastMsg = elapsed
            statusLabel.TextTransparency = 0.75
            statusLabel.Text = STATUS_MESSAGES[msgIdx]
            tw(statusLabel, {TextTransparency = 0}, 0.2)
            msgIdx = msgIdx + 1
        end
    end

    barFill.Size    = UDim2.new(1, 0, 1, 0)
    pctLabel.Text   = "100%"
    timerLabel.Text = LOAD_TIME .. "s  /  " .. LOAD_TIME .. "s"
    task.wait(0.35)

    fadeOut()
end

runLoadingScreen()
